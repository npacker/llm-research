# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- uv / virtualenv ----
# IMPORTANT: uv.lock is NOT ignored — it is committed for reproducible builds.
# Ignore only the local environment directory (the container env lives at
# /opt/venv, outside the workspace; this catches a stray host `uv` run).
.venv/
venv/

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_convert*

# ---- Secrets / local env ----
.env
.env.*
!.env.example
*.pem
.netrc
secrets.*

# ---- Experiment tracking & outputs ----
wandb/
runs/*
!runs/README.md
outputs/
logs/
*.log
checkpoints/
mlruns/
.tensorboard/

# ---- Large datasets under data/ (keep small fixtures + the README) ----
# Version large/generated corpora on the HF Hub, not git. Force-add a small
# intentional fixture with `git add -f <file>`.
data/**/*.parquet
data/**/*.arrow
data/**/*.jsonl
data/**/*.jsonl.gz
data/**/*.tar
data/**/*.tar.gz
data/**/*.zip
!data/README.md

# ---- Model weights / large binaries ----
# Keep these out of git — push to the HF Hub, or track with Git LFS (git-lfs is
# installed in the container) via `git lfs track "*.safetensors"`. Force-add an
# intentional small artifact with `git add -f <file>`.
*.safetensors
*.bin
*.gguf
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.msgpack

# Local model/data directories — uncomment and adjust to your layout:
# /models/
# /data/
# /datasets/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.swp
.idea/
# .vscode/        # uncomment if you don't want to share local editor settings

# nltk data must never be committed — routed to the HF cache volume
.nltk_data/
